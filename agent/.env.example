# Hermes Agent Environment Variables

# Required: Anthropic API key for Claude Opus
ANTHROPIC_API_KEY=sk-ant-...

# Required: Hermes MCP server URL (the notebook server)
HERMES_MCP_URL=http://hermes:3000/mcp/http

# Required: Secret key for the agent's Hermes identity
HERMES_SECRET_KEY=your-secret-key-here

# Required for Telegram: bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Optional for Discord: bot token
DISCORD_BOT_TOKEN=

# Allow all users to interact (set to false and use TELEGRAM_ALLOWED_USERS for restricted access)
GATEWAY_ALLOW_ALL_USERS=true
